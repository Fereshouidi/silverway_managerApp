{
  "expo": {
    "name": "Wassim app",
    "slug": "wassim-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/logo_black.png",
    "scheme": "manager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "notification": {
      "icon": "./app/assets/logo_black.png",
      "color": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fareshouidi.manager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/logo_black.png",
        "backgroundColor": "#000000"
      },
      "package": "com.fareshouidi.manager",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "NOTIFICATIONS"
      ],
      "includeAsyncStorage": true
    },
    "web": {
      "output": "static",
      "favicon": "./app/assets/logo_black.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./app/assets/logo_black.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./app/assets/logo_black.png",
          "color": "#000000",
          "sounds": [
            "./app/assets/sounds/notificationsound.mp4"
          ]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c909cf83-8f7d-4cd3-87bf-cc2806a028e0"
      }
    },
    "owner": "fareshouidi"
  }
}